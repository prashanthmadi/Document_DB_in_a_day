# =============================================================
# Document DB in a Day — Environment Configuration
# =============================================================
# Single configuration file used by Modules 3 and 4.
#
# Setup:
#   1. Copy this file to .env:  cp .env.template .env
#   2. Fill in your values from Module 1 setup
#
# NOTE: Do NOT commit the .env file — it contains secrets.
# =============================================================

# --- Azure DocumentDB Connection ---
# From Module 1, Part 1.4: Connection Strings page in Azure Portal
DOCUMENTDB_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster>.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256

# Database name (created in Module 1, Part 2.3)
DOCUMENTDB_DATABASE=trainingdb

# --- Azure OpenAI / AI Foundry ---
# From Module 1, Part 3: AI Foundry project deployments page
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Chat model deployment name (deployed in Module 1, Part 3.4)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Embedding model deployment name (deployed in Module 1, Part 3.3)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Embedding dimensions (must match Module 3 vectors: 256)
EMBEDDING_DIMENSIONS=256
